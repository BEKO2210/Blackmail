{
  "name": "aegis-switch",
  "version": "1.0.0",
  "private": true,
  "description": "AEGIS hosted Dead Man's Switch — Cloudflare Worker + D1 + Resend",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute aegis --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute aegis --local --file=./schema.sql",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
